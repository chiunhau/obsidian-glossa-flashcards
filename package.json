{
	"name": "glossa-flashcards-plugin",
	"version": "0.1.12",
	"description": "Obsidian plugin — turn any text into living vocabulary.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint src/",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"release": "bash scripts/release-plugin.sh"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"flashcard",
		"ai",
		"language",
		"learning"
	],
	"author": "chiunhau",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/parser": "^8.58.1",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"obsidian": "^1.12.2",
		"tslib": "2.4.0",
		"typescript": "^5.9.3"
	}
}
