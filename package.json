{
	"name": "glossa-flashcards-plugin",
	"version": "0.1.7",
	"description": "Obsidian plugin — turn any text into living vocabulary.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"release": "bash scripts/release-plugin.sh"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"flashcard",
		"ai",
		"language",
		"learning"
	],
	"author": "chiunhau",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.27.3",
		"obsidian": "^1.12.2",
		"tslib": "2.4.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.30",
		"ai": "^6.0.97",
		"zod": "^4.3.6"
	}
}
